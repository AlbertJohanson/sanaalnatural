<!doctype html>
<html class="js full-height" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#55823d">
    <link rel="canonical" href="{{ canonical_url }}">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>{{ shop.name }} - Próximamente</title>

    <meta name="description" content="{{ page_description | default: 'Estamos creando algo hermoso. Sé el primero en saber cuando lancemos.' | escape }}">

    {% render 'meta-tags' %}

    {{ content_for_header }}

    <!-- Google Fonts - Brand Typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    {% style %}
      /* Brand CSS Variables */
      :root {
        --color-primary: #55823d;
        --color-primary-dark: #31591d;
        --color-primary-light: #afea90;
        --color-white: #ffffff;
        --color-black: #000000;
        --color-background: #f8faf6;
        --color-text-muted: rgba(0, 0, 0, 0.6);
        --color-border: rgba(85, 130, 61, 0.2);
        --font-heading: 'Noto Serif', Georgia, serif;
        --font-body: 'Poppins', sans-serif;
      }

      * {
        box-sizing: border-box;
      }

      html, body {
        margin: 0;
        padding: 0;
        height: 100%;
      }

      body {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        font-family: var(--font-body);
      }

      .password-main {
        flex: 1;
        display: flex;
        flex-direction: column;
      }

      /* Password access button */
      .password-access {
        position: fixed;
        bottom: 1.5rem;
        right: 1.5rem;
        z-index: 100;
      }

      .password-access-btn {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.25rem;
        background: rgba(255, 255, 255, 0.95);
        border: 1px solid var(--color-border);
        border-radius: 30px;
        font-family: var(--font-body);
        font-size: 0.75rem;
        font-weight: 500;
        letter-spacing: 0.08em;
        color: var(--color-primary-dark);
        text-decoration: none;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 2px 15px rgba(85, 130, 61, 0.1);
      }

      .password-access-btn:hover {
        background: var(--color-white);
        border-color: var(--color-primary);
        transform: translateY(-2px);
        box-shadow: 0 4px 20px rgba(85, 130, 61, 0.15);
      }

      .password-access-btn svg {
        width: 14px;
        height: 14px;
        stroke: currentColor;
      }

      /* Modal overlay */
      .password-modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(49, 89, 29, 0.85);
        z-index: 1000;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        backdrop-filter: blur(4px);
      }

      .password-modal-overlay.active {
        display: flex;
      }

      .password-modal-content {
        background: var(--color-white);
        padding: 3rem;
        max-width: 400px;
        width: 100%;
        position: relative;
        animation: modalIn 0.3s ease;
      }

      @keyframes modalIn {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .modal-close {
        position: absolute;
        top: 1rem;
        right: 1rem;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.5rem;
        color: var(--color-primary-dark);
        transition: opacity 0.3s;
      }

      .modal-close:hover {
        opacity: 0.6;
      }

      .modal-title {
        font-family: var(--font-heading);
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--color-primary-dark);
        margin: 0 0 1.5rem;
        text-align: center;
      }

      .password-form {
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }

      .password-input {
        padding: 1rem;
        border: 1px solid var(--color-border);
        background: var(--color-background);
        font-family: var(--font-body);
        font-size: 0.95rem;
        outline: none;
        transition: border-color 0.3s;
      }

      .password-input:focus {
        border-color: var(--color-primary);
      }

      .password-submit {
        padding: 1rem;
        background: var(--color-primary);
        border: none;
        color: var(--color-white);
        font-family: var(--font-body);
        font-size: 0.8rem;
        font-weight: 500;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        cursor: pointer;
        transition: background 0.3s;
      }

      .password-submit:hover {
        background: var(--color-primary-dark);
      }

      .password-error {
        color: #c44d4d;
        font-family: var(--font-body);
        font-size: 0.85rem;
        text-align: center;
      }

      .admin-link {
        margin-top: 1.5rem;
        text-align: center;
        font-family: var(--font-body);
        font-size: 0.75rem;
        color: var(--color-text-muted);
      }

      .admin-link a {
        color: var(--color-primary);
        text-decoration: none;
      }

      .admin-link a:hover {
        text-decoration: underline;
      }
    {% endstyle %}

    <script src="{{ 'global.js' | asset_url }}" defer="defer"></script>
  </head>

  <body class="password">
    <a class="skip-to-content-link button visually-hidden" href="#MainContent">
      {{ 'accessibility.skip_to_text' | t }}
    </a>

    <main id="MainContent" class="password-main">
      {{ content_for_layout }}
    </main>

    <!-- Password access button -->
    <div class="password-access">
      <button class="password-access-btn" id="openPasswordModal">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
        Entrar con contraseña
      </button>
    </div>

    <!-- Password Modal -->
    <div class="password-modal-overlay" id="passwordModal">
      <div class="password-modal-content">
        <button class="modal-close" id="closePasswordModal" aria-label="Cerrar">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
        <h2 class="modal-title">Ingresar a la tienda</h2>
        {%- form 'storefront_password', class: 'password-form' -%}
          <input
            type="password"
            name="password"
            class="password-input"
            placeholder="Contraseña"
            autocomplete="current-password"
            {% if form.errors %}aria-invalid="true"{% endif %}
          >
          {%- if form.errors -%}
            <p class="password-error">Contraseña incorrecta. Intenta de nuevo.</p>
          {%- endif -%}
          <button type="submit" class="password-submit">Entrar</button>
        {%- endform -%}
        <p class="admin-link">¿Eres el dueño? <a href="/admin">Inicia sesión aquí</a></p>
      </div>
    </div>

    <script>
      document.addEventListener('DOMContentLoaded', function() {
        const openBtn = document.getElementById('openPasswordModal');
        const closeBtn = document.getElementById('closePasswordModal');
        const modal = document.getElementById('passwordModal');

        openBtn.addEventListener('click', function() {
          modal.classList.add('active');
          document.body.style.overflow = 'hidden';
        });

        closeBtn.addEventListener('click', function() {
          modal.classList.remove('active');
          document.body.style.overflow = '';
        });

        modal.addEventListener('click', function(e) {
          if (e.target === modal) {
            modal.classList.remove('active');
            document.body.style.overflow = '';
          }
        });

        // Open modal if there are form errors
        {% if form.errors %}
        modal.classList.add('active');
        {% endif %}
      });
    </script>

    <ul hidden>
      <li id="a11y-new-window-message">{{ 'accessibility.link_messages.new_window' | t }}</li>
    </ul>
  </body>
</html>
