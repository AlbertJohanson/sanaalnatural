{%- liquid
  assign heading = 'san.faq.heading' | t
  assign faq_eyebrow = 'san.faq.eyebrow' | t
  assign faq_description = 'san.faq.description' | t
  assign faq_contact = 'san.faq.contact_label' | t
  assign faqs = section.blocks
-%}

{{ 'section-san-faq.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #san-faq-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<section class="san-faq" id="san-faq-{{ section.id }}" data-faq>

  {%- comment -%} Living animated backdrop {%- endcomment -%}
  {%- render 'san-organic-bg', uid: section.id -%}

  <div class="san-faq__inner">

    {%- comment -%} ─── Intro column ─── {%- endcomment -%}
    <div class="san-faq__intro san-reveal san-reveal--left">
      {%- if faq_eyebrow != blank -%}
        <p class="san-faq__eyebrow"><i aria-hidden="true"></i>{{ faq_eyebrow }}</p>
      {%- endif -%}

      {%- if heading != blank -%}
        <h2 class="san-faq__heading">
          {%- assign hp = heading | split: '|' -%}
          {%- for part in hp -%}
            {%- if forloop.index == 2 -%}<em>{{ part }}</em>{%- else -%}{{ part }}{%- endif -%}
          {%- endfor -%}
        </h2>
      {%- endif -%}

      {%- if faq_description != blank -%}
        <p class="san-faq__desc">{{ faq_description }}</p>
      {%- endif -%}

      {%- if section.settings.show_contact and faq_contact != blank -%}
        <a href="{{ section.settings.contact_url | default: routes.root_url }}" class="san-faq__contact">
          <span>{{ faq_contact }}</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      {%- endif -%}
    </div>

    {%- comment -%} ─── Accordion column ─── {%- endcomment -%}
    <div class="san-faq__list san-reveal san-reveal--right">
      {%- if faqs.size > 0 -%}
        {%- for block in faqs -%}
          {%- assign is_open = false -%}
          {%- if forloop.first and section.settings.first_open -%}
            {%- assign is_open = true -%}
          {%- endif -%}
          {%- assign t_question = 'san.faq.items.' | append: forloop.index | append: '.question' | t -%}
          {%- if t_question contains 'translation missing' -%}{%- assign t_question = block.settings.question -%}{%- endif -%}
          {%- assign t_answer = 'san.faq.items.' | append: forloop.index | append: '.answer_html' | t -%}
          {%- if t_answer contains 'translation missing' -%}{%- assign t_answer = block.settings.answer -%}{%- endif -%}
          <div class="san-faq__item{% if is_open %} is-open{% endif %}" {{ block.shopify_attributes }}>
            <button
              class="san-faq__q"
              type="button"
              id="san-faq-q-{{ section.id }}-{{ forloop.index0 }}"
              aria-expanded="{% if is_open %}true{% else %}false{% endif %}"
              aria-controls="san-faq-a-{{ section.id }}-{{ forloop.index0 }}"
            >
              <span class="san-faq__q-text">{{ t_question }}</span>
              <span class="san-faq__icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
                  <line class="san-faq__icon-h" x1="5" y1="12" x2="19" y2="12"/>
                  <line class="san-faq__icon-v" x1="12" y1="5" x2="12" y2="19"/>
                </svg>
              </span>
            </button>
            <div
              class="san-faq__a"
              id="san-faq-a-{{ section.id }}-{{ forloop.index0 }}"
              role="region"
              aria-labelledby="san-faq-q-{{ section.id }}-{{ forloop.index0 }}"
              {% unless is_open %}aria-hidden="true"{% endunless %}
            >
              <div class="san-faq__a-inner">
                <div class="san-faq__a-text">{{ t_answer }}</div>
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        <p class="san-faq__empty">{{ 'san.faq.empty' | t }}</p>
      {%- endif -%}
    </div>

  </div>
</section>

{% javascript %}
  class SanFaq {
    constructor(el) {
      this.el = el;
      this.items = Array.from(el.querySelectorAll('.san-faq__item'));
      this.singleOpen = el.getAttribute('data-single-open') !== 'false';
      this.bind();
    }

    bind() {
      this.items.forEach((item) => {
        const btn = item.querySelector('.san-faq__q');
        const panel = item.querySelector('.san-faq__a');
        if (!btn || !panel) return;
        btn.addEventListener('click', () => this.toggle(item, btn, panel));
      });
    }

    toggle(item, btn, panel) {
      const willOpen = !item.classList.contains('is-open');

      if (willOpen && this.singleOpen) {
        this.items.forEach((other) => {
          if (other !== item) this.close(other);
        });
      }

      if (willOpen) {
        item.classList.add('is-open');
        btn.setAttribute('aria-expanded', 'true');
        panel.removeAttribute('aria-hidden');
      } else {
        this.close(item);
      }
    }

    close(item) {
      const btn = item.querySelector('.san-faq__q');
      const panel = item.querySelector('.san-faq__a');
      item.classList.remove('is-open');
      if (btn) btn.setAttribute('aria-expanded', 'false');
      if (panel) panel.setAttribute('aria-hidden', 'true');
    }
  }

  function initSanFaq(scope) {
    (scope || document).querySelectorAll('[data-faq]').forEach((el) => {
      if (!el._sanFaq) el._sanFaq = new SanFaq(el);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => initSanFaq());
  } else {
    initSanFaq();
  }
  document.addEventListener('shopify:section:load', (e) => initSanFaq(e.target));
{% endjavascript %}

{% schema %}
{
  "name": "Preguntas frecuentes",
  "tag": "section",
  "class": "san-faq-section",
  "max_blocks": 16,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Resolvemos tus dudas"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "info": "Usa | para resaltar parte del título en verde claro.",
      "default": "Preguntas |frecuentes|"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Descripción",
      "default": "Todo lo que necesitas saber sobre nuestros productos, envíos y compromiso con lo natural."
    },
    {
      "type": "checkbox",
      "id": "first_open",
      "label": "Abrir la primera pregunta por defecto",
      "default": true
    },
    {
      "type": "header",
      "content": "Llamado a la acción"
    },
    {
      "type": "checkbox",
      "id": "show_contact",
      "label": "Mostrar enlace de contacto",
      "default": true
    },
    {
      "type": "text",
      "id": "contact_label",
      "label": "Texto del enlace",
      "default": "¿Más preguntas? Escríbenos"
    },
    {
      "type": "url",
      "id": "contact_url",
      "label": "Enlace de contacto"
    },
    {
      "type": "header",
      "content": "Espaciado"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Espaciado superior",
      "default": 108
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Espaciado inferior",
      "default": 108
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Pregunta",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Pregunta",
          "default": "¿Cuál es tu pregunta?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Respuesta",
          "default": "<p>Escribe aquí la respuesta a la pregunta.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Preguntas frecuentes",
      "blocks": [
        {
          "type": "faq",
          "settings": {
            "question": "¿Sus productos son 100% naturales?",
            "answer": "<p>Sí. Todos nuestros productos están formulados con ingredientes naturales seleccionados, sin aditivos ni conservantes artificiales.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "¿Cuánto tarda el envío?",
            "answer": "<p>Los pedidos se procesan en 24–48 horas y llegan en 3 a 5 días hábiles. El envío es gratis en compras superiores a $500.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "¿Cuentan con certificación orgánica?",
            "answer": "<p>Trabajamos con productores certificados que garantizan procesos agrícolas sostenibles y responsables.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "¿Puedo devolver un producto?",
            "answer": "<p>Claro. Aceptamos devoluciones dentro de los 30 días posteriores a la compra. Escríbenos y te ayudamos con el proceso.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
