{%- liquid
  assign show_heading = section.settings.show_heading
  assign heading = section.settings.heading
  assign layout = section.settings.layout
-%}

{{ 'section-san-categories.css' | asset_url | stylesheet_tag }}

<section
  class="san-categories san-reveal"
  id="san-cats-{{ section.id }}"
  data-layout="{{ layout }}"
>
  {%- if show_heading and heading != blank -%}
    <div class="san-categories__header">
      <h2 class="san-categories__heading">{{ heading }}</h2>
      <div class="san-categories__heading-line" aria-hidden="true"></div>
    </div>
  {%- endif -%}

  <div
    class="san-categories__grid"
    data-count="{{ section.blocks.size }}"
    data-layout="{{ layout }}"
  >
    {%- for block in section.blocks -%}
      {%- assign delay_class = 'san-reveal-d' | append: forloop.index -%}
      {%- if forloop.index > 5 -%}
        {%- assign delay_class = 'san-reveal-d5' -%}
      {%- endif -%}
      <a
        href="{{ block.settings.url | default: '/collections/all' }}"
        class="san-cat-card san-reveal {{ delay_class }}"
        {{ block.shopify_attributes }}
        aria-label="{{ block.settings.title }}"
      >
        <div class="san-cat-card__media">
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 800
              | image_tag:
                class: 'san-cat-card__img',
                loading: 'lazy',
                widths: '400, 600, 800',
                sizes: '(max-width: 749px) 100vw, (max-width: 1199px) 50vw, 33vw',
                alt: block.settings.title
            }}
          {%- else -%}
            <div class="san-cat-card__placeholder">
              {{ 'collection-1' | placeholder_svg_tag: 'san-cat-card__ph-svg' }}
            </div>
          {%- endif -%}
          <div class="san-cat-card__overlay"></div>
          {%- if block.settings.label != blank -%}
            <span class="san-cat-card__badge">{{ block.settings.label }}</span>
          {%- endif -%}
        </div>

        <div class="san-cat-card__content">
          <h3 class="san-cat-card__title">{{ block.settings.title }}</h3>
          {%- if block.settings.subtitle != blank -%}
            <p class="san-cat-card__subtitle">{{ block.settings.subtitle }}</p>
          {%- endif -%}
          <span class="san-cat-card__cta">
            Explorar
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </span>
        </div>
      </a>
    {%- else -%}
      <p class="san-categories__empty">Agrega categorías desde el editor de tema.</p>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Categorías",
  "tag": "div",
  "class": "san-categories-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Mostrar título",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título de sección",
      "default": "Explora nuestras categorías"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Diseño",
      "options": [
        { "value": "editorial", "label": "Editorial (asimétrico)" },
        { "value": "grid",      "label": "Cuadrícula uniforme" }
      ],
      "default": "editorial"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Categoría",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Categoría"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtítulo (opcional)"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Enlace"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Etiqueta superpuesta (opcional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Categorías",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "title": "Suplementos",
            "subtitle": "Cuida tu cuerpo desde adentro",
            "url": "/collections/suplementos"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Superalimentos",
            "subtitle": "Potencia tu nutrición",
            "url": "/collections/superalimentos"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Aceites Esenciales",
            "subtitle": "Aromaterapia y bienestar",
            "url": "/collections/aceites-esenciales"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Tés e Infusiones",
            "subtitle": "Rituales de calma diaria",
            "url": "/collections/tes-infusiones"
          }
        }
      ]
    }
  ],
  "max_blocks": 6
}
{% endschema %}
