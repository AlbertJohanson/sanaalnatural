{% comment %}
  SANA AL NATURAL - Coming Soon Section
  A beautiful, organic-inspired landing page
  Using brand colors and typography from BRAND_GUIDELINES.md
{% endcomment %}

<style>
  /* Google Fonts - Brand Typography */
  @import url('https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400&family=Poppins:wght@300;400;500;600;700&display=swap');

  /* Brand CSS Variables */
  :root {
    /* Colores principales */
    --color-primary: #55823d;
    --color-primary-dark: #31591d;
    --color-primary-light: #afea90;
    --color-white: #ffffff;
    --color-black: #000000;

    /* Colores derivados */
    --color-background: #f8faf6;
    --color-background-soft: #f0f4ed;
    --color-text-muted: rgba(0, 0, 0, 0.6);
    --color-border: rgba(85, 130, 61, 0.2);

    /* Tipografía */
    --font-heading: 'Noto Serif', Georgia, serif;
    --font-body: 'Poppins', sans-serif;
  }

  .coming-soon-wrapper {
    min-height: 100vh;
    background: var(--color-background);
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* Animated organic background shapes */
  .organic-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .organic-shape {
    position: absolute;
    border-radius: 60% 40% 50% 50% / 50% 60% 40% 50%;
    opacity: 0.12;
    animation: float 20s ease-in-out infinite;
  }

  .organic-shape-1 {
    width: 600px;
    height: 600px;
    background: var(--color-primary);
    top: -200px;
    right: -150px;
    animation-delay: 0s;
  }

  .organic-shape-2 {
    width: 400px;
    height: 400px;
    background: var(--color-primary-light);
    bottom: -100px;
    left: -100px;
    animation-delay: -7s;
    border-radius: 40% 60% 50% 50% / 60% 40% 60% 40%;
  }

  .organic-shape-3 {
    width: 300px;
    height: 300px;
    background: var(--color-primary-dark);
    top: 40%;
    left: 10%;
    animation-delay: -14s;
    opacity: 0.06;
  }

  @keyframes float {
    0%, 100% {
      transform: translate(0, 0) rotate(0deg) scale(1);
    }
    25% {
      transform: translate(20px, -30px) rotate(5deg) scale(1.02);
    }
    50% {
      transform: translate(-10px, 20px) rotate(-3deg) scale(0.98);
    }
    75% {
      transform: translate(15px, 10px) rotate(2deg) scale(1.01);
    }
  }

  /* Grain texture overlay */
  .grain-overlay {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    opacity: 0.025;
    pointer-events: none;
  }

  /* Main content */
  .coming-soon-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    position: relative;
    z-index: 10;
    text-align: center;
  }

  /* Decorative leaf element */
  .leaf-decoration {
    width: 70px;
    height: auto;
    margin-bottom: 2rem;
    opacity: 0;
    animation: fadeInUp 1s ease-out 0.3s forwards;
  }

  .leaf-decoration svg {
    width: 100%;
    height: auto;
    stroke: var(--color-primary);
    fill: none;
  }

  /* Brand name */
  .brand-name {
    font-family: var(--font-heading);
    font-size: clamp(2.2rem, 7vw, 4rem);
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-primary-dark);
    margin: 0 0 0.5rem 0;
    opacity: 0;
    animation: fadeInUp 1s ease-out 0.5s forwards;
  }

  .brand-tagline {
    font-family: var(--font-body);
    font-size: clamp(0.75rem, 2vw, 0.9rem);
    font-weight: 400;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 3rem;
    opacity: 0;
    animation: fadeInUp 1s ease-out 0.7s forwards;
  }

  /* Divider line */
  .elegant-divider {
    width: 60px;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--color-primary), transparent);
    margin: 0 auto 3rem;
    opacity: 0;
    animation: fadeInUp 1s ease-out 0.8s forwards;
  }

  /* Main headline */
  .coming-soon-headline {
    font-family: var(--font-heading);
    font-size: clamp(1.6rem, 4.5vw, 2.5rem);
    font-weight: 400;
    font-style: italic;
    color: var(--color-black);
    margin: 0 0 1.5rem 0;
    line-height: 1.3;
    opacity: 0;
    animation: fadeInUp 1s ease-out 0.9s forwards;
  }

  /* Subtitle */
  .coming-soon-subtitle {
    font-family: var(--font-body);
    font-size: clamp(0.95rem, 2.5vw, 1.05rem);
    font-weight: 300;
    color: var(--color-text-muted);
    max-width: 500px;
    line-height: 1.8;
    margin: 0 auto 3rem;
    opacity: 0;
    animation: fadeInUp 1s ease-out 1s forwards;
  }

  /* Newsletter form */
  .newsletter-form {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    width: 100%;
    max-width: 450px;
    margin-bottom: 2rem;
    opacity: 0;
    animation: fadeInUp 1s ease-out 1.1s forwards;
  }

  .newsletter-form-inner {
    display: flex;
    width: 100%;
    gap: 0;
    background: var(--color-white);
    overflow: hidden;
    box-shadow: 0 4px 30px rgba(85, 130, 61, 0.1);
    border: 1px solid var(--color-border);
    transition: all 0.4s ease;
  }

  .newsletter-form-inner:focus-within {
    box-shadow: 0 8px 40px rgba(85, 130, 61, 0.15);
    border-color: var(--color-primary);
  }

  .email-input {
    flex: 1;
    padding: 1.2rem 1.5rem;
    border: none;
    background: transparent;
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--color-black);
    letter-spacing: 0.02em;
    outline: none;
  }

  .email-input::placeholder {
    color: var(--color-text-muted);
  }

  .submit-btn {
    padding: 1.2rem 2rem;
    background: var(--color-primary);
    border: none;
    color: var(--color-white);
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .submit-btn:hover {
    background: var(--color-primary-dark);
  }

  .form-message {
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-primary);
    margin-top: 0.5rem;
  }

  /* Countdown section */
  .countdown-section {
    margin-top: 2rem;
    opacity: 0;
    animation: fadeInUp 1s ease-out 1.2s forwards;
  }

  .countdown-label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .countdown-timer {
    display: flex;
    gap: 2rem;
    justify-content: center;
  }

  .countdown-item {
    text-align: center;
  }

  .countdown-number {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 6vw, 3rem);
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1;
    display: block;
  }

  .countdown-unit {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-top: 0.5rem;
    display: block;
  }

  /* Footer */
  .coming-soon-footer {
    padding: 2rem;
    text-align: center;
    position: relative;
    z-index: 10;
    opacity: 0;
    animation: fadeInUp 1s ease-out 1.4s forwards;
  }

  .social-links {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-bottom: 1.5rem;
  }

  .social-link {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-border);
    border-radius: 50%;
    color: var(--color-primary);
    transition: all 0.3s ease;
  }

  .social-link:hover {
    border-color: var(--color-primary);
    background: var(--color-primary);
    color: var(--color-white);
    transform: translateY(-2px);
  }

  .social-link svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
  }

  .footer-text {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Mobile adjustments */
  @media (max-width: 600px) {
    .countdown-timer {
      gap: 1rem;
    }

    .newsletter-form-inner {
      flex-direction: column;
    }

    .submit-btn {
      width: 100%;
      padding: 1rem;
    }

    .brand-name {
      letter-spacing: 0.1em;
    }
  }
</style>

<div class="coming-soon-wrapper">
  <!-- Animated organic background -->
  <div class="organic-bg">
    <div class="organic-shape organic-shape-1"></div>
    <div class="organic-shape organic-shape-2"></div>
    <div class="organic-shape organic-shape-3"></div>
  </div>
  <div class="grain-overlay"></div>

  <!-- Main Content -->
  <div class="coming-soon-content">
    <!-- Decorative leaf -->
    <div class="leaf-decoration">
      <svg viewBox="0 0 100 120" xmlns="http://www.w3.org/2000/svg">
        <path d="M50 5 C30 25, 15 50, 20 80 C25 100, 45 115, 50 115 C55 115, 75 100, 80 80 C85 50, 70 25, 50 5 Z M50 20 C50 20, 50 90, 50 110" stroke-width="2"/>
        <path d="M50 35 C40 45, 35 55, 38 65 M50 50 C60 60, 65 70, 62 80" stroke-width="1.5"/>
      </svg>
    </div>

    <!-- Brand -->
    <h1 class="brand-name">{{ section.settings.brand_name | default: 'Sana Al Natural' }}</h1>
    <p class="brand-tagline">{{ section.settings.brand_tagline | default: 'Natural & Organic' }}</p>

    <div class="elegant-divider"></div>

    <!-- Headline -->
    <h2 class="coming-soon-headline">{{ section.settings.headline | default: 'Algo hermoso está creciendo' }}</h2>
    <p class="coming-soon-subtitle">{{ section.settings.subtitle | default: 'Estamos creando una colección de productos naturales para tu bienestar. Sé el primero en descubrir nuestra historia.' }}</p>

    <!-- Newsletter Form -->
    {%- form 'customer', class: 'newsletter-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="newsletter-form-inner">
        <input
          type="email"
          name="contact[email]"
          class="email-input"
          placeholder="{{ section.settings.email_placeholder | default: 'Tu correo electrónico' }}"
          required
          autocomplete="email"
        >
        <button type="submit" class="submit-btn">
          {{ section.settings.button_text | default: 'Notificarme' }}
        </button>
      </div>
      {%- if form.posted_successfully? -%}
        <p class="form-message">{{ section.settings.success_message | default: 'Gracias por unirte a nuestro viaje.' }}</p>
      {%- endif -%}
    {%- endform -%}

    <!-- Countdown -->
    {% if section.settings.show_countdown %}
    <div class="countdown-section">
      <p class="countdown-label">{{ section.settings.countdown_label | default: 'Lanzamos en' }}</p>
      <div class="countdown-timer" id="countdown">
        <div class="countdown-item">
          <span class="countdown-number" id="days">00</span>
          <span class="countdown-unit">Días</span>
        </div>
        <div class="countdown-item">
          <span class="countdown-number" id="hours">00</span>
          <span class="countdown-unit">Horas</span>
        </div>
        <div class="countdown-item">
          <span class="countdown-number" id="minutes">00</span>
          <span class="countdown-unit">Min</span>
        </div>
        <div class="countdown-item">
          <span class="countdown-number" id="seconds">00</span>
          <span class="countdown-unit">Seg</span>
        </div>
      </div>
    </div>
    {% endif %}
  </div>

  <!-- Footer -->
  <div class="coming-soon-footer">
    <div class="social-links">
      {%- if settings.social_instagram_link != blank -%}
        <a href="{{ settings.social_instagram_link }}" class="social-link" aria-label="Instagram" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
        </a>
      {%- endif -%}
      {%- if settings.social_facebook_link != blank -%}
        <a href="{{ settings.social_facebook_link }}" class="social-link" aria-label="Facebook" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
      {%- endif -%}
      {%- if settings.social_pinterest_link != blank -%}
        <a href="{{ settings.social_pinterest_link }}" class="social-link" aria-label="Pinterest" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 0C5.373 0 0 5.372 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738.098.119.112.224.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12 0-6.628-5.373-12-12-12z"/>
          </svg>
        </a>
      {%- endif -%}
      {%- if settings.social_tiktok_link != blank -%}
        <a href="{{ settings.social_tiktok_link }}" class="social-link" aria-label="TikTok" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
          </svg>
        </a>
      {%- endif -%}
    </div>
    <p class="footer-text">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. Todos los derechos reservados.</p>
  </div>
</div>

{% if section.settings.show_countdown %}
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const launchDate = new Date('{{ section.settings.launch_date | default: "2025-06-01" }}T00:00:00').getTime();

    function updateCountdown() {
      const now = new Date().getTime();
      const distance = launchDate - now;

      if (distance > 0) {
        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        document.getElementById('days').textContent = String(days).padStart(2, '0');
        document.getElementById('hours').textContent = String(hours).padStart(2, '0');
        document.getElementById('minutes').textContent = String(minutes).padStart(2, '0');
        document.getElementById('seconds').textContent = String(seconds).padStart(2, '0');
      }
    }

    updateCountdown();
    setInterval(updateCountdown, 1000);
  });
</script>
{% endif %}

{% schema %}
{
  "name": "Coming Soon",
  "settings": [
    {
      "type": "text",
      "id": "brand_name",
      "label": "Nombre de marca",
      "default": "Sana Al Natural"
    },
    {
      "type": "text",
      "id": "brand_tagline",
      "label": "Tagline",
      "default": "Natural & Organic"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Título principal",
      "default": "Algo hermoso está creciendo"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Estamos creando una colección de productos naturales para tu bienestar. Sé el primero en descubrir nuestra historia."
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Placeholder del email",
      "default": "Tu correo electrónico"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Texto del botón",
      "default": "Notificarme"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Mensaje de éxito",
      "default": "Gracias por unirte a nuestro viaje."
    },
    {
      "type": "checkbox",
      "id": "show_countdown",
      "label": "Mostrar cuenta regresiva",
      "default": true
    },
    {
      "type": "text",
      "id": "countdown_label",
      "label": "Etiqueta del countdown",
      "default": "Lanzamos en"
    },
    {
      "type": "text",
      "id": "launch_date",
      "label": "Fecha de lanzamiento (YYYY-MM-DD)",
      "default": "2025-06-01"
    }
  ],
  "presets": [
    {
      "name": "Coming Soon"
    }
  ]
}
{% endschema %}
