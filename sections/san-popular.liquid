{{ 'section-san-popular.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign collection = collections[section.settings.collection]
  assign products   = collection.products | default: empty
  assign limit      = section.settings.products_to_show | default: 4
  assign heading    = section.settings.heading | default: 'Lo más buscado'
  assign eyebrow    = section.settings.eyebrow | default: 'Tendencias'
  assign cta_label  = section.settings.cta_label | default: 'Ver todo'
  assign cta_url    = section.settings.cta_url | default: '/collections/all'
-%}

<section class="san-popular" id="san-popular-{{ section.id }}">

  <div class="san-popular__header san-reveal san-reveal--up">
    <div class="san-popular__header-text">
      {%- if eyebrow != blank -%}
        <span class="san-popular__eyebrow">{{ eyebrow }}</span>
      {%- endif -%}
      <h2 class="san-popular__heading">{{ heading }}</h2>
    </div>
    {%- if cta_label != blank -%}
      <a href="{{ cta_url }}" class="san-popular__cta-link">
        {{ cta_label }}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    {%- endif -%}
  </div>

  <div class="san-popular__grid">
    {%- if products.size > 0 -%}
      {%- for product in products limit: limit -%}
        {%- assign rank = forloop.index -%}
        {%- assign rank_str = rank | prepend: '0' -%}
        {%- if rank >= 10 -%}{%- assign rank_str = rank | append: '' -%}{%- endif -%}

        <a
          href="{{ product.url }}"
          class="san-popular__card san-reveal san-reveal--up san-reveal-d{{ forloop.index }}"
          aria-label="{{ product.title }}"
        >
          <span class="san-popular__rank" aria-hidden="true">{{ rank_str }}</span>

          <div class="san-popular__img-wrap">
            {%- if product.featured_image -%}
              {{
                product.featured_image
                | image_url: width: 600
                | image_tag:
                  class: 'san-popular__img',
                  loading: 'lazy',
                  widths: '300, 450, 600',
                  sizes: '(max-width: 749px) 50vw, 25vw',
                  alt: product.title
              }}
            {%- else -%}
              <div class="san-popular__placeholder">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {%- endif -%}

            {%- if product.available == false -%}
              <span class="san-popular__badge">Agotado</span>
            {%- elsif product.compare_at_price > product.price -%}
              <span class="san-popular__badge san-popular__badge--sale">Oferta</span>
            {%- endif -%}

            <div class="san-popular__overlay" aria-hidden="true">
              <span class="san-popular__quick-btn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                  <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                </svg>
                Ver producto
              </span>
            </div>
          </div>

          <div class="san-popular__body">
            {%- if product.vendor != blank and section.settings.show_vendor -%}
              <span class="san-popular__vendor">{{ product.vendor }}</span>
            {%- endif -%}

            <h3 class="san-popular__title">{{ product.title }}</h3>

            <div class="san-popular__price-row">
              <span class="san-popular__price">
                {{ product.price | money }}
              </span>
              {%- if product.compare_at_price > product.price -%}
                <span class="san-popular__compare-price">
                  {{ product.compare_at_price | money }}
                </span>
              {%- endif -%}
            </div>
          </div>
        </a>
      {%- endfor -%}
    {%- else -%}
      {%- for i in (1..limit) -%}
        {%- assign rank_str = i | prepend: '0' -%}
        <div class="san-popular__card san-reveal san-reveal--up san-reveal-d{{ i }}">
          <span class="san-popular__rank" aria-hidden="true">{{ rank_str }}</span>
          <div class="san-popular__img-wrap">
            <div class="san-popular__placeholder">
              {{ 'product-' | append: i | placeholder_svg_tag }}
            </div>
          </div>
          <div class="san-popular__body">
            <h3 class="san-popular__title">Producto {{ i }}</h3>
            <div class="san-popular__price-row">
              <span class="san-popular__price">$XXX.00</span>
            </div>
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>

</section>

{% schema %}
{
  "name": "Más Buscados",
  "tag": "div",
  "class": "san-popular-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto pequeño sobre el título",
      "default": "Tendencias"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título de la sección",
      "default": "Lo más buscado"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Colección"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4,
      "label": "Productos a mostrar"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Mostrar marca del producto",
      "default": false
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Texto del enlace",
      "default": "Ver todo"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Enlace"
    }
  ],
  "presets": [
    {
      "name": "Más Buscados"
    }
  ]
}
{% endschema %}
