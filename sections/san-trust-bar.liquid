{%- liquid
  assign show_section = section.settings.show_section
  assign bg_variant = section.settings.bg_variant
-%}

{%- if show_section -%}
<section
  class="san-trust"
  id="san-trust-{{ section.id }}"
  data-variant="{{ bg_variant }}"
  aria-label="Beneficios de la marca"
>
  <div class="san-trust__marquee">
    <div class="san-trust__track">
      {%- for rep in (1..3) -%}
        {%- for block in section.blocks -%}
          <div
            class="san-trust__item"
            aria-hidden="{{ forloop.parentloop.index | minus: 1 | greater_than: 0 }}"
            {{ block.shopify_attributes }}
          >
            <span class="san-trust__icon" aria-hidden="true">
              {%- case block.settings.icon -%}
                {%- when 'leaf' -%}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M12 2C8 2 4 6 4 10c0 4 5 8 8 10 3-2 8-6 8-10 0-4-4-8-8-8z" stroke="currentColor" stroke-width="1.5" fill="none"/>
                    <path d="M12 2v20M8 6c2 2 4 5 4 6M16 6c-2 2-4 5-4 6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                  </svg>
                {%- when 'check' -%}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <polyline points="20 6 9 17 4 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                {%- when 'truck' -%}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <rect x="1" y="3" width="15" height="13" rx="1" stroke="currentColor" stroke-width="1.5"/>
                    <polygon points="16 8 20 8 23 11 23 16 16 16 16 8" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                    <circle cx="5.5" cy="18.5" r="2.5" stroke="currentColor" stroke-width="1.5"/>
                    <circle cx="18.5" cy="18.5" r="2.5" stroke="currentColor" stroke-width="1.5"/>
                  </svg>
                {%- when 'star' -%}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                  </svg>
                {%- when 'heart' -%}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                  </svg>
                {%- when 'shield' -%}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                  </svg>
              {%- endcase -%}
            </span>
            <span class="san-trust__label">{{ block.settings.label }}</span>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}

{% stylesheet %}
  /* Loaded via tag below — kept empty to avoid duplication */
{% endstylesheet %}

{{ 'section-san-trust-bar.css' | asset_url | stylesheet_tag }}

{% javascript %}
(function() {
  var sanObserver = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (e.isIntersecting) {
        e.target.classList.add('is-visible');
        sanObserver.unobserve(e.target);
      }
    });
  }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.san-reveal').forEach(function(el) {
    sanObserver.observe(el);
  });

  document.addEventListener('shopify:section:load', function() {
    document.querySelectorAll('.san-reveal:not(.is-visible)').forEach(function(el) {
      sanObserver.observe(el);
    });
  });
})();
{% endjavascript %}

{% schema %}
{
  "name": "Trust Bar",
  "tag": "div",
  "class": "san-trust-bar-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Mostrar sección",
      "default": true
    },
    {
      "type": "select",
      "id": "bg_variant",
      "label": "Variante de fondo",
      "options": [
        { "value": "light", "label": "Claro" },
        { "value": "dark", "label": "Oscuro" }
      ],
      "default": "light"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Beneficio",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Texto",
          "default": "Beneficio de marca"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Ícono",
          "options": [
            { "value": "leaf",   "label": "Hoja" },
            { "value": "check",  "label": "Check" },
            { "value": "truck",  "label": "Camión" },
            { "value": "star",   "label": "Estrella" },
            { "value": "heart",  "label": "Corazón" },
            { "value": "shield", "label": "Escudo" }
          ],
          "default": "leaf"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Bar",
      "blocks": [
        { "type": "item", "settings": { "label": "100% Natural",             "icon": "leaf"   } },
        { "type": "item", "settings": { "label": "Sin Conservantes",          "icon": "check"  } },
        { "type": "item", "settings": { "label": "Envío Gratis +$500",        "icon": "truck"  } },
        { "type": "item", "settings": { "label": "Hecho con Amor",            "icon": "heart"  } },
        { "type": "item", "settings": { "label": "Certificado Orgánico",      "icon": "star"   } },
        { "type": "item", "settings": { "label": "5000+ Clientes Felices",    "icon": "shield" } }
      ]
    }
  ],
  "max_blocks": 8
}
{% endschema %}
