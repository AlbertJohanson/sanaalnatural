{% comment %}
  Renders the Sana Al Natural mobile drawer.
  Full-screen editorial menu with search, large navigation,
  cart status, account, and social links.

  Usage:
  {% render 'header-drawer' %}
{% endcomment %}

<header-drawer data-breakpoint="{% if section.settings.menu_type_desktop == 'drawer' %}desktop{% else %}tablet{% endif %}">
  <details id="Details-menu-drawer-container" class="menu-drawer-container">
    <summary
      class="san-drawer-toggle header__icon header__icon--menu header__icon--summary link focus-inset"
      aria-label="{{ 'sections.header.menu' | t }}"
    >
      <span>
        <svg class="san-hamburger" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
          <line x1="4" y1="7" x2="20" y2="7"/>
          <line x1="4" y1="12" x2="20" y2="12"/>
          <line x1="4" y1="17" x2="16" y2="17"/>
        </svg>
        <svg class="san-hamburger-close" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
          <path d="M18 6L6 18M6 6l12 12"/>
        </svg>
      </span>
    </summary>
    <div id="menu-drawer" class="san-drawer gradient menu-drawer motion-reduce color-{{ section.settings.menu_color_scheme }}">
      <div class="san-drawer__inner menu-drawer__inner-container">

        <button
          class="san-drawer__close"
          aria-label="{{ 'accessibility.close' | t }}"
          onclick="document.querySelector('#Details-menu-drawer-container > summary').click()"
        >
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
            <path d="M18 6L6 18M6 6l12 12"/>
          </svg>
        </button>

        <div class="san-drawer__search">
          <form action="{{ routes.search_url }}" method="get" role="search">
            <div class="san-drawer__search-field">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="11" cy="11" r="8"/>
                <path d="M21 21l-4.35-4.35"/>
              </svg>
              <input
                type="search"
                name="q"
                placeholder="{{ 'general.search.search' | t }}"
                class="san-drawer__search-input"
                autocomplete="off"
              >
              <input type="hidden" name="options[prefix]" value="last">
            </div>
          </form>
        </div>

        <nav class="san-drawer__nav menu-drawer__navigation" aria-label="{{ 'general.navigation.menu' | t }}">
          <ul class="san-drawer__menu menu-drawer__menu list-menu" role="list">
            {%- for link in section.settings.menu.links -%}
              <li class="san-drawer__menu-item" style="--item-index: {{ forloop.index }}">
                {%- if link.links != blank -%}
                  <details id="Details-drawer-menu-{{ forloop.index }}">
                    <summary class="san-drawer__link san-drawer__link--parent">
                      <span>{{ link.title | escape }}</span>
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
                        <path d="M12 5v14M5 12h14"/>
                      </svg>
                    </summary>
                    <ul class="san-drawer__submenu" role="list">
                      {%- for childlink in link.links -%}
                        <li>
                          {%- if childlink.links == blank -%}
                            <a
                              href="{{ childlink.url }}"
                              class="san-drawer__sublink"
                              {% if childlink.current %}aria-current="page"{% endif %}
                            >
                              {{ childlink.title | escape }}
                            </a>
                          {%- else -%}
                            <details class="san-drawer__nested-details">
                              <summary class="san-drawer__sublink san-drawer__sublink--parent">
                                {{ childlink.title | escape }}
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                              </summary>
                              <ul class="san-drawer__submenu san-drawer__submenu--nested" role="list">
                                {%- for grandchildlink in childlink.links -%}
                                  <li>
                                    <a
                                      href="{{ grandchildlink.url }}"
                                      class="san-drawer__sublink san-drawer__sublink--nested"
                                      {% if grandchildlink.current %}aria-current="page"{% endif %}
                                    >
                                      {{ grandchildlink.title | escape }}
                                    </a>
                                  </li>
                                {%- endfor -%}
                              </ul>
                            </details>
                          {%- endif -%}
                        </li>
                      {%- endfor -%}
                    </ul>
                  </details>
                {%- else -%}
                  <a
                    href="{{ link.url }}"
                    class="san-drawer__link"
                    {% if link.current %}aria-current="page"{% endif %}
                  >
                    {{ link.title | escape }}
                  </a>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        </nav>

        <div class="san-drawer__divider" aria-hidden="true"></div>

        <a href="{{ routes.cart_url }}" class="san-drawer__cart-status">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
            <path d="M16 10a4 4 0 01-8 0"/>
          </svg>
          <span>{{ 'templates.cart.cart' | t }}{%- if cart != empty %} ({{ cart.item_count }}){%- endif -%}</span>
        </a>

        {%- if shop.customer_accounts_enabled -%}
          <a
            href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
            class="san-drawer__account"
            rel="nofollow"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
            <span>
              {%- if customer -%}
                {{ 'customer.account_fallback' | t }}
              {%- else -%}
                {{ 'customer.log_in' | t }}
              {%- endif -%}
            </span>
          </a>
        {%- endif -%}

        <div class="san-drawer__footer">
          <ul class="san-drawer__social list-unstyled" role="list">
            {%- if settings.social_instagram_link != blank -%}
              <li>
                <a href="{{ settings.social_instagram_link }}" class="link" aria-label="{{ 'general.social.links.instagram' | t }}">
                  <span class="svg-wrapper">{{- 'icon-instagram.svg' | inline_asset_content -}}</span>
                </a>
              </li>
            {%- endif -%}
            {%- if settings.social_facebook_link != blank -%}
              <li>
                <a href="{{ settings.social_facebook_link }}" class="link" aria-label="{{ 'general.social.links.facebook' | t }}">
                  <span class="svg-wrapper">{{- 'icon-facebook.svg' | inline_asset_content -}}</span>
                </a>
              </li>
            {%- endif -%}
            {%- if settings.social_tiktok_link != blank -%}
              <li>
                <a href="{{ settings.social_tiktok_link }}" class="link" aria-label="{{ 'general.social.links.tiktok' | t }}">
                  <span class="svg-wrapper">{{- 'icon-tiktok.svg' | inline_asset_content -}}</span>
                </a>
              </li>
            {%- endif -%}
            {%- if settings.social_twitter_link != blank -%}
              <li>
                <a href="{{ settings.social_twitter_link }}" class="link" aria-label="{{ 'general.social.links.twitter' | t }}">
                  <span class="svg-wrapper">{{- 'icon-twitter.svg' | inline_asset_content -}}</span>
                </a>
              </li>
            {%- endif -%}
            {%- if settings.social_pinterest_link != blank -%}
              <li>
                <a href="{{ settings.social_pinterest_link }}" class="link" aria-label="{{ 'general.social.links.pinterest' | t }}">
                  <span class="svg-wrapper">{{- 'icon-pinterest.svg' | inline_asset_content -}}</span>
                </a>
              </li>
            {%- endif -%}
            {%- if settings.social_youtube_link != blank -%}
              <li>
                <a href="{{ settings.social_youtube_link }}" class="link" aria-label="{{ 'general.social.links.youtube' | t }}">
                  <span class="svg-wrapper">{{- 'icon-youtube.svg' | inline_asset_content -}}</span>
                </a>
              </li>
            {%- endif -%}
            {%- if settings.social_tumblr_link != blank -%}
              <li>
                <a href="{{ settings.social_tumblr_link }}" class="link" aria-label="{{ 'general.social.links.tumblr' | t }}">
                  <span class="svg-wrapper">{{- 'icon-tumblr.svg' | inline_asset_content -}}</span>
                </a>
              </li>
            {%- endif -%}
            {%- if settings.social_snapchat_link != blank -%}
              <li>
                <a href="{{ settings.social_snapchat_link }}" class="link" aria-label="{{ 'general.social.links.snapchat' | t }}">
                  <span class="svg-wrapper">{{- 'icon-snapchat.svg' | inline_asset_content -}}</span>
                </a>
              </li>
            {%- endif -%}
            {%- if settings.social_vimeo_link != blank -%}
              <li>
                <a href="{{ settings.social_vimeo_link }}" class="link" aria-label="{{ 'general.social.links.vimeo' | t }}">
                  <span class="svg-wrapper">{{- 'icon-vimeo.svg' | inline_asset_content -}}</span>
                </a>
              </li>
            {%- endif -%}
          </ul>
        </div>

      </div>
    </div>
  </details>
</header-drawer>
